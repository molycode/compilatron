set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR x86_64)

if(NOT DEFINED CMAKE_C_COMPILER)
	if(DEFINED ENV{CTRN_GCC_PATH})
		set(CMAKE_C_COMPILER "$ENV{CTRN_GCC_PATH}/bin/gcc")
	else()
		set(CMAKE_C_COMPILER "gcc")
	endif()
endif()

if(NOT DEFINED CMAKE_CXX_COMPILER)
	if(DEFINED ENV{CTRN_GCC_PATH})
		set(CMAKE_CXX_COMPILER "$ENV{CTRN_GCC_PATH}/bin/g++")
	else()
		set(CMAKE_CXX_COMPILER "g++")
	endif()
endif()

if(DEFINED ENV{CTRN_GCC_PATH})
	# Bake in the RPATH so the binary finds the custom libstdc++ at runtime
	set(CMAKE_BUILD_RPATH "$ENV{CTRN_GCC_PATH}/lib64")
	set(CMAKE_INSTALL_RPATH "$ENV{CTRN_GCC_PATH}/lib64")
	message(STATUS "Using GCC from CTRN_GCC_PATH: $ENV{CTRN_GCC_PATH}")
else()
	message(STATUS "Using system GCC (set CTRN_GCC_PATH to use custom GCC)")
endif()

message(STATUS "CMAKE_C_COMPILER = ${CMAKE_C_COMPILER}")
message(STATUS "CMAKE_CXX_COMPILER = ${CMAKE_CXX_COMPILER}")
