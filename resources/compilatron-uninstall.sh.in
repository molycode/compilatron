#!/bin/bash
# Compilatron uninstaller — generated by CMake at build time
# Removes all files installed by 'cmake --install' / 'make install'

PREFIX="@CMAKE_INSTALL_PREFIX@"
BINDIR="@CMAKE_INSTALL_FULL_BINDIR@"
DATADIR="@CMAKE_INSTALL_FULL_DATAROOTDIR@"

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

remove_file()
{
	if [ -f "$1" ]; then
		rm -f "$1" && echo -e "  ${GREEN}removed${NC} $1" || echo -e "  ${RED}failed${NC}  $1"
	fi
}

remove_dir_if_empty()
{
	if [ -d "$1" ] && [ -z "$(ls -A "$1")" ]; then
		rmdir "$1"
	fi
}

echo "Uninstalling Compilatron from $PREFIX ..."
echo ""

remove_file "$BINDIR/compilatron"
remove_file "$BINDIR/ctrn/fonts/Roboto-Medium.ttf"
remove_file "$BINDIR/ctrn/fonts/fa-solid-900.ttf"
remove_dir_if_empty "$BINDIR/ctrn/fonts"

remove_file "$DATADIR/applications/compilatron.desktop"
remove_file "$DATADIR/icons/hicolor/32x32/apps/compilatron.png"
remove_file "$DATADIR/icons/hicolor/48x48/apps/compilatron.png"
remove_file "$DATADIR/icons/hicolor/128x128/apps/compilatron.png"
remove_file "$DATADIR/icons/hicolor/256x256/apps/compilatron.png"

# Refresh caches (silent — tools may not be present)
update-desktop-database -q "$DATADIR/applications" 2>/dev/null || true
gtk-update-icon-cache -q -t -f "$DATADIR/icons/hicolor" 2>/dev/null || true

# Remove self last
remove_file "$BINDIR/compilatron-uninstall"

# Data directory — contains user configs, presets, logs, and built compilers.
# When launched from the desktop (no terminal), use a GUI dialog; otherwise prompt.
DATADIR_APP="$BINDIR/ctrn"
if [ -d "$DATADIR_APP" ]; then
	remove_data=false
	msg="Remove application data?\n\n$DATADIR_APP\n\nThis includes your configs, presets, logs, and any compilers you built.\nThis cannot be undone."

	if command -v zenity >/dev/null 2>&1; then
		zenity --question --title="Compilatron" --text="$msg" \
			--ok-label="Remove" --cancel-label="Keep" 2>/dev/null && remove_data=true
	elif command -v kdialog >/dev/null 2>&1; then
		kdialog --title "Compilatron" --yesno "$msg" \
			--yes-label "Remove" --no-label "Keep" 2>/dev/null && remove_data=true
	else
		echo ""
		echo "Data directory found: $DATADIR_APP"
		echo "This contains your configs, presets, logs, and any compilers you built."
		printf "Remove it? [y/N] "
		read -r answer
		if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
			remove_data=true
		fi
	fi

	if [ "$remove_data" = true ]; then
		rm -rf "$DATADIR_APP"
		echo -e "  ${GREEN}removed${NC} $DATADIR_APP"
	else
		echo "  kept   $DATADIR_APP"
	fi
fi

echo ""
echo "Done."
