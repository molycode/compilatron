{
	"version": 6,
	"cmakeMinimumRequired": {
		"major": 4,
		"minor": 3,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "ctrn-base",
			"hidden": true
		},
		{
			"name": "ctrn-linux-gcc-debug",
			"inherits": "ctrn-base",
			"displayName": "ctrn_linux_gcc_debug",
			"description": "Debug build with GCC (uses CTRN_GCC_PATH or system GCC)",
			"condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/gcc-Debug",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux/gcc.cmake",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
			}
		},
		{
			"name": "ctrn-linux-gcc-release",
			"inherits": "ctrn-base",
			"displayName": "ctrn_linux_gcc_release",
			"description": "Release build with GCC (uses CTRN_GCC_PATH or system GCC)",
			"condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/gcc-Release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux/gcc.cmake",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
			}
		},
		{
			"name": "ctrn-linux-clang-debug",
			"inherits": "ctrn-base",
			"displayName": "ctrn_linux_clang_debug",
			"description": "Debug build with Clang (uses CTRN_CLANG_PATH or system Clang)",
			"condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/clang-Debug",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux/clang.cmake",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
			}
		},
		{
			"name": "ctrn-linux-clang-release",
			"inherits": "ctrn-base",
			"displayName": "ctrn_linux_clang_release",
			"description": "Release build with Clang (uses CTRN_CLANG_PATH or system Clang)",
			"condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/clang-Release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux/clang.cmake",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
			}
		}
	],
	"buildPresets": [
		{
			"name": "ctrn-linux-gcc-debug",
			"configurePreset": "ctrn-linux-gcc-debug",
			"condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
		},
		{
			"name": "ctrn-linux-gcc-release",
			"configurePreset": "ctrn-linux-gcc-release",
			"condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
		},
		{
			"name": "ctrn-linux-clang-debug",
			"configurePreset": "ctrn-linux-clang-debug",
			"condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
		},
		{
			"name": "ctrn-linux-clang-release",
			"configurePreset": "ctrn-linux-clang-release",
			"condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
		}
	]
}
